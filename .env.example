# QWE Community — Netlify Environment Variables
# Set these in Netlify → Site Settings → Environment Variables

# Postgres connection string (use Neon, Supabase, or Railway for a free DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
SESSION_SECRET=change-me-to-a-long-random-string

# Gmail SMTP (for OTP verification emails)
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password

# Admin account seeding (run seed script once, then remove)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
